# =============================================================================
# QuantaAlpha environment configuration template
#
# Usage:
#   1. cp configs/.env.example .env
#   2. Sesuaikan <PROJECT_ROOT> dengan path absolut folder proyek kamu
#      Contoh JarvisLabs: /workspace/ai-agent
#      Contoh lokal:      /home/ubuntu/project/multi-agent-system
#   3. Isi HF_TOKEN untuk download model dan dataset
# =============================================================================

# =============================================================================
# Paths — sesuaikan dengan environment kamu
# Ganti <PROJECT_ROOT>/backend dengan path absolut ke folder backend/
# =============================================================================

# Qlib data directory (hasil unzip cn_data.zip; harus berisi calendars/, features/, instruments/)
QLIB_DATA_DIR=<PROJECT_ROOT>/backend/data/qlib/cn_data

# Qlib provider URI (biasanya sama dengan QLIB_DATA_DIR)
QLIB_PROVIDER_URI=<PROJECT_ROOT>/backend/data/qlib/cn_data

# Workspace untuk file sementara hasil coding agent
# Jika tidak di-set, otomatis menggunakan <backend>/data/results/workspace
WORKSPACE_PATH=<PROJECT_ROOT>/backend/data/results/workspace

# Pickle cache untuk menyimpan hasil komputasi
# Jika tidak di-set, otomatis menggunakan <backend>/data/results/pickle_cache
PICKLE_CACHE_FOLDER_PATH_STR=<PROJECT_ROOT>/backend/data/results/pickle_cache

# Path ke HDF5 source data untuk factor mining
# Jika tidak di-set, otomatis menggunakan <backend>/git_ignore_folder/factor_implementation_source_data
FACTOR_CoSTEER_DATA_FOLDER=<PROJECT_ROOT>/backend/git_ignore_folder/factor_implementation_source_data
FACTOR_CoSTEER_DATA_FOLDER_DEBUG=<PROJECT_ROOT>/backend/git_ignore_folder/factor_implementation_source_data_debug

# =============================================================================
# HuggingFace — untuk download model Qwen3 dan dataset
# Buat token di: https://huggingface.co/settings/tokens
# =============================================================================
HF_TOKEN=<your_hf_token>

# Izinkan transformers download model Qwen3 dari HF jika belum di cache lokal.
# Default kode adalah local_files_only=True (offline) — set 0 untuk run pertama,
# set 1 (atau hapus baris ini) setelah model tersimpan di cache.
HF_LOCAL_ONLY=0

# =============================================================================
# LLM API — opsional jika latent.enabled=true di experiment.yaml
# Diperlukan hanya jika latent.enabled=false (mode API eksternal)
# =============================================================================
OPENAI_API_KEY=<your_api_key>
OPENAI_BASE_URL=<your_base_url>

# Models untuk mode API eksternal
REASONING_MODEL=<your_model>
CHAT_MODEL=<your_model>

# Embedding (opsional, untuk RAG/KNN retrieval)
# EMBEDDING_MODEL=text-embedding-v4
# EMBEDDING_API_KEY=<your_embedding_key>
# EMBEDDING_BASE_URL=<your_embedding_url>

# =============================================================================
# Global — biasanya tidak perlu diubah
# =============================================================================
USE_LOCAL=True
MAX_RETRY=5
RETRY_WAIT_SECONDS=5
FACTOR_MINING_TIMEOUT=999999
CHAT_MAX_TOKENS=4000
CHAT_TEMPERATURE=0.7
